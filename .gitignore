.gitignore:

####################################
# General
####################################
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.old
*.orig
.DS_Store
Thumbs.db

####################################
# .NET / Visual Studio
####################################
bin/
obj/
out/

.vs/
.vscode/

*.user
*.suo
*.userosscache

# Rider / Resharper
.idea/
*.DotSettings.user

# NuGet
*.nupkg
packages/
.nuget/

####################################
# ASP.NET Core
####################################
appsettings.Development.json
appsettings.Local.json

# Secrets
secrets.json

####################################
# Entity Framework
####################################
Migrations/*.Designer.cs
# (keep actual migrations, ignore designer files only if needed)

####################################
# Node / Vue.js
####################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

####################################
# Vue build output
####################################
dist/
dist-ssr/

####################################
# Environment files
####################################
.env
.env.*
!.env.example

####################################
# TypeScript
####################################
*.tsbuildinfo

####################################
# Tests
####################################
coverage/

####################################
# Logs
####################################
logs/
